{
    "version": "2.0.0",
    "tasks": [
{%- if "javafx" in stack.packs %}
        {
            "label": "JavaFX : lancer (via Maven)",
            "type": "shell",
            "command": "./mvnw verify javafx:run",
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": []
        },
{%- else %}
        {
            "label": "Lancer l'application (via Maven)",
            "type": "shell",
            "command": "./mvnw compile exec:java",
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": []
        },
{%- endif %}
        {
            "label": "Tests : tous",
            "type": "shell",
            "command": "./mvnw test",
            "group": { "kind": "test", "isDefault": true },
            "problemMatcher": []
        },
        {
            "label": "Build complet",
            "type": "shell",
            "command": "./mvnw verify",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "./mvnw clean",
            "problemMatcher": []
        },
        {
            "label": "Formater le code (Spotless)",
            "type": "shell",
            "command": "./mvnw spotless:apply",
            "problemMatcher": []
        }
    ]
}
